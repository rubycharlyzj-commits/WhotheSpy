import { db } from "../firebase.js";
import {
  doc,
  setDoc
} from "https://www.gstatic.com/firebasejs/12.0.0/firebase-firestore.js";

export async function joinRoom(roomCode, playerId, playerName) {N
  await setDoc(
    doc(db, "rooms", roomCode, "players", playerId),
    {
      name: playerName,
      joinedAt: Date.now()
    }
  );
}