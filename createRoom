import { db } from "../firebase.js";
import {
  doc,
  setDoc
} from "https://www.gstatic.com/firebasejs/12.0.0/firebase-firestore.js";

export async function createRoom(roomCode, hostName) {
  await setDoc(doc(db, "rooms", roomCode), {
    host: hostName,
    gameState: "waiting",
    createdAt: Date.now()
  });
}S